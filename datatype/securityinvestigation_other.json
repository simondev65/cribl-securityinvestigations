{
  "id": "securityinvestigation_other",
  "minRawLength": 256,
  "rules": [
    {
      "condition": "dataSource=='aws:elb:accesslogs'",
      "type": "json",
      "timestampAnchorRegex": "/http/",
      "timestamp": {
        "type": "auto",
        "length": 150
      },
      "timestampTimezone": "local",
      "timestampEarliest": "-1773771136s",
      "timestampLatest": "+10years",
      "maxEventBytes": 51200,
      "disabled": false,
      "parserEnabled": true,
      "shouldUseDataRaw": true,
      "parser": {
        "mode": "extract",
        "type": "elff",
        "srcField": "_raw",
        "fields": [
          "timestamp",
          "elb",
          "client_port",
          "backend_port",
          "request_processing_time",
          "backend_processing_time",
          "response_processing_time",
          "elb_status_code",
          "backend_status_code",
          "received_bytes",
          "sent_bytes",
          "request",
          "user_agent",
          "ssl_cipher",
          "ssl_protocol"
        ]
      },
      "eventBreakerRegex": "/[\\n\\r]+(?!\\s)/",
      "name": "aws:elb:accesslog",
      "fields": [
        {
          "name": "datatype",
          "value": "'securityinvestigation_other_aws:elb:accesslog'"
        }
      ]
    },
    {
