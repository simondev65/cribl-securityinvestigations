      "parserEnabled": true,
      "shouldUseDataRaw": true,
      "parser": {
        "mode": "extract",
        "type": "clf",
        "srcField": "_raw",
        "iterations": 100,
        "overwrite": false,
        "regex": "/^(?<bucket_owner>\\S+)\\s+(?<bucket>\\S+)\\s+\\[(?<time>[^\\]]+)\\]\\s+(?<remote_ip>\\S+)\\s+(?<requester>\\S+)\\s+(?<request_id>\\S+)\\s+(?<operation>\\S+)\\s+(?<key>\\S+)\\s+(?<request>\"[^\"]*\")\\s+(?<status>\\d{3}|-)\\s+(?<error>\\S+)\\s+(?<bytes_sent>\\S+)\\s+(?<object_size>\\S+)\\s+(?<total_time>\\S+)\\s+(?<turn_around_time>\\S+)\\s+(?<referrer>\"[^\"]*\"|-)\\s+(?<user_agent>\"[^\"]*\"|-)\\s+(?<version_id>\\S+)$/",
        "fields": [
          "bucket_owner",
          "bucket",
          "time",
          "remote_ip",
          "requester",
          "request_id",
          "operation",
          "key",
          "request",
          "http_status",
